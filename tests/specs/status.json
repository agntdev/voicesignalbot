[
  {
    "name": "/status shows monitoring status",
    "steps": [
      {
        "send": { "text": "/status" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Show current monitoring status and recent activity log\n\nNo chats monitored yet.\n\nVoice: neutral, normal"
            }
          }
        ]
      }
    ]
  },
  {
    "name": "Status callback shows monitoring status",
    "steps": [
      {
        "send": { "callback": "status:show" },
        "expect": [
          {
            "method": "editMessageText",
            "payload": {
              "text": "Show current monitoring status and recent activity log\n\nNo chats monitored yet.\n\nVoice: neutral, normal"
            }
          }
        ]
      }
    ]
  }
]
